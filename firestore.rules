rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Whitelisted admin check helper
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // User Profile matching rule
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Admin whitelist collection rules
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Survey questions rules
    match /questions/{qid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Survey assessment submission rules
    match /assessments/{aid} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
