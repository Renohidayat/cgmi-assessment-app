rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Whitelisted admin check helper
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // User profiles – public read/write (kode-akses auth, no Firebase Auth)
    match /users/{uid} {
      allow read, write: if true;
    }

    // Admin whitelist collection – admin only
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Survey questions – public read, admin write
    match /questions/{qid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Assessment submissions – public create/read, admin write
    match /assessments/{aid} {
      allow create: if true;
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
